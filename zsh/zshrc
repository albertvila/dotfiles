if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

export PATH=~/bin:~/.local/bin:$PATH
# Add pip user scripts to PATH dynamically (avoids hardcoding a Python version)
export PATH="$(python3 -m site --user-base 2>/dev/null)/bin:$PATH"
export EDITOR="vim"

# If no GPG Suite https://help.github.com/articles/telling-git-about-your-gpg-key/
export GPG_TTY=$TTY

# Adding colors to more & less commands, cat is also colored with an alias
export MORE='-R'
export LESSOPEN='|bat --color=always --style=plain %s'
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=3"

# Configure iTerm2 tab titles based on current directory, example /Users/Albert/workspace/dotfiles -> ~/p/dotfiles
precmd () {
  window_title="\e]0;${${PWD/#"$HOME"/~}/workspace/w}\a"
  echo -ne "$window_title"
}

if [[ -d ~/.plenv ]]; then
  export PLENV_ROOT=~/.plenv
  export PLENV_SHELL=zsh
  PLENV_VERSION=$(<$PLENV_ROOT/version)
  export PATH="$PLENV_ROOT/shims:$PLENV_ROOT/versions/$PLENV_VERSION/bin:$PATH"
fi

# Lazy-load jenv: only init when java/jenv is first called
if [[ -d "$HOME/.jenv" ]]; then
  export PATH="$HOME/.jenv/bin:$PATH"
  jenv() {
    unfunction jenv
    eval "$(command jenv init - --no-rehash)"
    jenv "$@"
  }
  java() {
    unfunction java
    eval "$(command jenv init - --no-rehash)"
    java "$@"
  }
fi

check-local-java() {
  [[ -a .java-version ]] || return

  if [[ -f .java-version && -r .java-version ]]; then
    command printf "Now using local version of java: $(cat .java-version)\n"
  fi
}

# Automatically switch java version when entering a directory with a .java-version file
autoload -U add-zsh-hook
add-zsh-hook chpwd check-local-java

# load bashcompinit for some old bash completions (compinit is already called by Prezto's completion module)
autoload -U +X bashcompinit && bashcompinit

for script in $HOME/.scripts/*; do
  source $script
done

# Used to import private scripts stored in my bitbucket repository
if [[ -d "$HOME/.scripts.private" ]]; then
  for script in $HOME/.scripts.private/*; do
    source $script
  done
fi

setopt hist_ignore_all_dups # remove older duplicate entries from history
setopt hist_reduce_blanks # remove superfluous blanks from history items
setopt inc_append_history # save history entries as soon as they are entered
setopt share_history # share history between different instances of the shell

export PYENV_ROOT="$HOME/.pyenv"
# Lazy-load pyenv: only init when python/pip/pyenv is first called
if [[ -d "$PYENV_ROOT" ]]; then
  export PATH="$PYENV_ROOT/bin:$PATH"
  pyenv() {
    unfunction pyenv python python3 pip pip3
    eval "$(command pyenv init -)"
    pyenv "$@"
  }
  python()  { unfunction pyenv python python3 pip pip3; eval "$(command pyenv init -)"; python  "$@" }
  python3() { unfunction pyenv python python3 pip pip3; eval "$(command pyenv init -)"; python3 "$@" }
  pip()     { unfunction pyenv python python3 pip pip3; eval "$(command pyenv init -)"; pip     "$@" }
  pip3()    { unfunction pyenv python python3 pip pip3; eval "$(command pyenv init -)"; pip3    "$@" }
fi

# zsh users - add the following line to your ~/.zshrc
eval "$(direnv hook zsh)"

# add prompt_starship_setup function to Prezto (written once during install, see lib/dotfiles.sh)
setopt prompt_subst interactive_comments

# Lazy-load nodenv: only init when node/npm/npx is first called
if [[ -d "$HOME/.nodenv" ]]; then
  export PATH="$HOME/.nodenv/bin:$PATH"
  nodenv() {
    unfunction nodenv node npm npx
    eval "$(command nodenv init -)"
    nodenv "$@"
  }
  node() { unfunction nodenv node npm npx; eval "$(command nodenv init -)"; node "$@" }
  npm()  { unfunction nodenv node npm npx; eval "$(command nodenv init -)"; npm  "$@" }
  npx()  { unfunction nodenv node npm npx; eval "$(command nodenv init -)"; npx  "$@" }
fi
