[push]
	default = simple
[core]
	editor = vim
	excludesfile = ~/.gitignore
[merge]
	ff = false
[pull]
	rebase = merges
[commit]
	template = ~/.gitmessage
	gpgsign = true
	verbose = true
[includeIf "gitdir:~/workspace/"]
	path = ~/.gitconfig-lm
[credential "https://github.com"]
	helper = !/usr/bin/env gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/env gh auth git-credential
[include]
    path = ~/.gitconfig-user
